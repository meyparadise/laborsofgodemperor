{
	"nodes":[
		{"id":"g-page","type":"group","x":-400,"y":-900,"width":400,"height":170,"color":"4","label":"Admin Page"},
		{"id":"g-t1","type":"group","x":-940,"y":-700,"width":460,"height":520,"color":"5","label":"Tab 1: Heroes"},
		{"id":"g-t2","type":"group","x":-420,"y":-700,"width":460,"height":520,"color":"3","label":"Tab 2: Quests"},
		{"id":"g-t3","type":"group","x":100,"y":-700,"width":460,"height":460,"color":"6","label":"Tab 3: Gear & Cards"},
		{"id":"g-t4","type":"group","x":620,"y":-700,"width":480,"height":650,"color":"1","label":"Tab 4: Player (replaces cheat panel)"},
		{"id":"g-t5","type":"group","x":-940,"y":-140,"width":460,"height":420,"color":"2","label":"Tab 5: Store"},
		{"id":"g-t6","type":"group","x":-420,"y":-140,"width":460,"height":420,"color":"4","label":"Tab 6: Economy"},
